SECRET_KEY=change-this-to-a-long-random-string-in-production
ANTHROPIC_API_KEY=sk-ant-...   # get from https://console.anthropic.com/
DATABASE_URL=sqlite:///./stockview.db

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:8000/api/subscription/webhook

# Optional: pin specific price IDs (app auto-creates them if omitted)
# STRIPE_PRICE_BEGINNER=price_...
# STRIPE_PRICE_INTERMEDIATE=price_...
# STRIPE_PRICE_COMMERCIAL=price_...

FRONTEND_URL=http://localhost:5173

# Email (SMTP) — required for password reset, email verification, and price alerts
# Gmail example: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=Stockview <you@gmail.com>
# Leave SMTP_USER blank to disable all email sending (the app will run fine without it)
